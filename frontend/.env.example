# Runtime: web3 or circle
VITE_APP_RUNTIME=web3
VITE_ONS_NETWORK=devnet

# Public client configuration. Values prefixed with VITE_ are bundled into the app.
VITE_ONS_RPC=
VITE_ONS_CONTRACT=
VITE_ONS_EXPLORER=
VITE_BASE_PATH=/

# Optional comma-separated RFC-O-1 wallet allowlist.
VITE_ONS_WALLETS=

# Optional read-performance controls.
VITE_ONS_VIEW_CONCURRENCY=4
VITE_ONS_PAGE_SIZE=25
VITE_ONS_VIEW_RPC_CONCURRENCY=4
VITE_ONS_RPC_BATCH_MS=16
VITE_ONS_RPC_BATCH_SIZE=32
VITE_ONS_RPC_TIMEOUT_MS=15000
VITE_ONS_VIEW_CACHE_MS=30000

# Development server only.
VITE_DEV_RPC_UPSTREAM=
VITE_ALLOWED_HOSTS=
