# Contract toolchain configuration. Never commit a funded private key.
AML_NETWORK=devnet
AML_RPC=
AML_EXPLORER=

AML_CONTRACT=ons.aml
AML_CONTRACT_NAME=octra_identity
AML_CONSTRUCTOR_ARGS=[]

# Required only for deployment and other signed operations.
AML_DEPLOYER_ADDR=
AML_DEPLOYER_PRIV=

# Optional fee floors in ou.
AML_DEPLOY_FEE_OU=200000
AML_CALL_FEE_OU=1000
